rules_version = '2';

// Regras de isolamento multi-tenant do SmartLoop.
// [SmartLoop][Security] tenantId == uid do dono (1 dono = 1 loja no MVP).
// O acesso é decidido por request.auth.uid == tenantId — NÃO por um campo
// editável pelo usuário —, evitando escalonamento entre tenants.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(tenantId) {
      return isSignedIn() && request.auth.uid == tenantId;
    }

    // Perfil do usuário — cada um lê/escreve apenas o seu, e o tenantId
    // é imutável e travado ao próprio uid (defesa em profundidade).
    match /users/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create: if isSignedIn() && request.auth.uid == uid
                    && request.resource.data.tenantId == uid;
      allow update: if isSignedIn() && request.auth.uid == uid
                    && request.resource.data.tenantId == resource.data.tenantId;
      allow delete: if false;
    }

    // Repositório de bugs/sugestões (beta) — coleção restrita.
    // Qualquer usuário logado cria o próprio relato; só admins/devs leem e triam.
    function isBugAdmin() {
      return isSignedIn() && request.auth.token.email in [
        "ads.deyvid@gmail.com", "deyvid.win7@gmail.com", "pvrgeral@gmail.com"
      ];
    }
    match /bugReports/{id} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update: if isBugAdmin();
      allow delete: if false;
    }

    // Loja (tenant) e todas as subcoleções (customers, serviceOrders, parts,
    // products, sales, transactions, technicians, suppliers, quotes...).
    match /tenants/{tenantId} {
      allow read: if isOwner(tenantId);
      allow create: if isOwner(tenantId)
                    && request.resource.data.ownerId == request.auth.uid;
      // Não permite trocar o dono de uma loja já criada.
      allow update: if isOwner(tenantId)
                    && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if false;

      match /{document=**} {
        allow read, write: if isOwner(tenantId);
      }
    }
  }
}
