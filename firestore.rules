rules_version = '2';

// Regras de isolamento multi-tenant do SmartLoop.
// [SmartLoop][Security] tenantId == uid do dono (1 dono = 1 loja no MVP).
// Acesso decidido por:
//   - isOwner(tenantId): request.auth.uid == tenantId (acesso total)
//   - isTechnician(tenantId, optionalCollection): request.auth.uid eh um tecnico
//     ativo do tenant, com permissao TRUE para a subcolecao acessada.
//
// NUNCA confiar no campo `role` ou `tenantId` do doc do proprio usuario para
// decisao de acesso. As permissoes sao verificadas em isTechnician() atraves
// do doc /tenants/{tenantId}/technicians/{techUid}.
//
// Subcolecoes RESTRITAS ao dono (tecnico NAO acessa): financeiro, relatorios,
// configuracoes. Tudo mais (os, clientes, estoque, pdv, orcamentos, fornecedores,
// garantia, technicians) eh acessivel ao tecnico desde que a permissao do doc
// dele seja true (default true; configuravel em iteracao futura).
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(tenantId) {
      return isSignedIn() && request.auth.uid == tenantId;
    }

    function isBugAdmin() {
      return isSignedIn() && request.auth.token.email in [
        "ads.deyvid@gmail.com", "deyvid.win7@gmail.com", "pvrgeral@gmail.com"
      ];
    }

    // Subcolecoes que o tecnico NAO pode acessar. O dono (isOwner) sempre acessa.
    function isRestrictedToOwner(collection) {
      return collection in ['financeiro', 'relatorios', 'configuracoes'];
    }

    // Verifica se o caller eh um tecnico ATIVO do tenant E (se collection
    // passada) tem permissao TRUE naquela subcolecao. NUNCA confiar no
    // request.resource.data do proprio doc — lemos /tenants/{tid}/technicians/{uid}.
    function isTechnician(tenantId, optionalCollection) {
      return isSignedIn()
          && request.auth.uid != tenantId
          && (optionalCollection == null || !isRestrictedToOwner(optionalCollection))
          && get(/databases/$(database)/documents/tenants/$(tenantId)/technicians/$(request.auth.uid)).data.active == true
          && get(/databases/$(database)/documents/tenants/$(tenantId)/technicians/$(request.auth.uid)).data.inviteStatus == 'active';
    }

    // Perfil do usuario — cada um le/escreve o seu. Dono (uid == tenantId) tem
    // doc proprio; tecnico (uid != tenantId) tbm pode criar seu users/{uid} na
    // bootstrap, e depois editar apenas o seu. Backend (Cloud Functions admin) le/
    // escreve livremente via Admin SDK.
    match /users/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create: if isSignedIn() && request.auth.uid == uid
                    && request.resource.data.tenantId == uid;
      allow update: if isSignedIn() && request.auth.uid == uid
                    && request.resource.data.tenantId == resource.data.tenantId;
      // Dono tambem pode ler o doc de cada tecnico do seu tenant (lista de membros)
      allow read, update: if isSignedIn()
                          && get(/databases/$(database)/documents/tenants/$(request.auth.uid)/technicians/$(uid)).data.uid == uid;
      allow delete: if false;
    }

    // Repositorio de bugs/sugestoes (beta) — restrito a admins/devs.
    match /bugReports/{id} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update: if isBugAdmin();
      allow delete: if false;
    }

    // Loja (tenant) e subcolecoes.
    match /tenants/{tenantId} {
      allow read: if isOwner(tenantId);
      allow create: if isOwner(tenantId)
                    && request.resource.data.ownerId == request.auth.uid;
      allow update: if isOwner(tenantId)
                    && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if false;

      // Subcolecoes (customers, serviceOrders, parts, products, sales, transactions,
      // technicians, suppliers, quotes, etc).
      // Regra antiga: so o dono lia/escrevia. Nova: dono total, OU tecnico
      // ativo (sem subcolecoes restritas).
      match /{collection}/{doc=**} {
        allow read, write: if isOwner(tenantId) || isTechnician(tenantId, collection);
      }
    }

    // Bio publico (link-in-bio do SmartLoop).
    match /bioPage/{doc=**} {
      allow read: if true;
      allow write: if isBugAdmin();
    }

    match /bioEvents/{eventId} {
      allow read, write: if false;
    }

    match /bioStats/{doc=**} {
      allow read: if isBugAdmin();
      allow write: if false;
    }
  }
}