rules_version = '2';

// Regras de isolamento multi-tenant do SmartLoop.
// [SmartLoop][Security] tenantId == uid do dono (1 dono = 1 loja no MVP).
// Acesso decidido por:
//   - isOwner(tenantId): request.auth.uid == tenantId (acesso total)
//   - isTechnician(tenantId, optionalCollection): request.auth.uid eh um tecnico
//     ATIVO do tenant (doc /tenants/{tenantId}/technicians/{request.auth.uid} existe
//     com active=true E inviteStatus=active), E (se collection passada) nao eh
//     restrita ao owner.
//
// Subcolecoes RESTRITAS ao dono (tecnico NAO acessa): financeiro, relatorios,
// configuracoes. Tudo mais (clientes, serviceOrders, parts, products, sales,
// suppliers, quotes, technicians, garantia, orcamentos) eh acessivel.
//
// IMPORTANTE: o doc do tecnico em tenants/{tenantId}/technicians tem ID == uid
// (definido na Cloud Function inviteTechnician via doc(uid)). Sem isso, a regra
// abaixo nao consegue resolver o doc via get(path com request.auth.uid).
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(tenantId) {
      return isSignedIn() && request.auth.uid == tenantId;
    }

    function isBugAdmin() {
      return isSignedIn() && request.auth.token.email in [
        "ads.deyvid@gmail.com", "deyvid.win7@gmail.com", "pvrgeral@gmail.com"
      ];
    }

    function isRestrictedToOwner(collection) {
      return collection in ['financeiro', 'relatorios', 'configuracoes'];
    }

    // Tecnico ATIVO do tenant (doc do tecnico com ID == auth.uid, active=true,
    // inviteStatus=active). Substitui isTechnician antigo que tentava fazer get
    // com path estatico.
    function isTechnician(tenantId, optionalCollection) {
      return isSignedIn()
          && request.auth.uid != tenantId
          && (optionalCollection == null || !isRestrictedToOwner(optionalCollection))
          && exists(/databases/$(database)/documents/tenants/$(tenantId)/technicians/$(request.auth.uid))
          && get(/databases/$(database)/documents/tenants/$(tenantId)/technicians/$(request.auth.uid)).data.active == true
          && get(/databases/$(database)/documents/tenants/$(tenantId)/technicians/$(request.auth.uid)).data.inviteStatus == 'active';
    }

    // Perfil do usuario.
    match /users/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create: if isSignedIn() && request.auth.uid == uid
                    && request.resource.data.tenantId == uid;
      allow update: if isSignedIn() && request.auth.uid == uid
                    && request.resource.data.tenantId == resource.data.tenantId;
      // Dono pode ler docs de tecnicos do seu tenant (lista de membros).
      allow read, update: if isSignedIn()
                          && get(/databases/$(database)/documents/tenants/$(request.auth.uid)/technicians/$(uid)).data.uid == uid;
      allow delete: if false;
    }

    // Repositorio de bugs/sugestoes (beta).
    match /bugReports/{id} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update: if isBugAdmin();
      allow delete: if false;
    }

    // Loja (tenant) e subcolecoes.
    match /tenants/{tenantId} {
      // Dono sempre le/escreve. Tecnico tambem le o tenant (necessario pra
      // header/dashboard saber nome/logo) mas NAO cria/edita.
      allow read: if isOwner(tenantId) || isTechnician(tenantId, null);
      allow create: if isOwner(tenantId) && request.resource.data.ownerId == request.auth.uid;
      allow update: if isOwner(tenantId) && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if false;

      // Subcolecoes (customers, serviceOrders, parts, products, sales, transactions,
      // technicians, suppliers, quotes, garantia).
      match /{collection}/{doc=**} {
        allow read, write: if isOwner(tenantId) || isTechnician(tenantId, collection);
      }
    }

    // Bio publico.
    match /bioPage/{doc=**} {
      allow read: if true;
      allow write: if isBugAdmin();
    }
    match /bioEvents/{eventId} {
      allow read, write: if false;
    }
    match /bioStats/{doc=**} {
      allow read: if isBugAdmin();
      allow write: if false;
    }
  }
}