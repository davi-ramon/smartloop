rules_version = '2';

// Arquivos do SmartLoop (logos, imagens de produto, fotos de OS) isolados por tenant.
// No MVP, tenantId == uid do dono, então validamos direto pelo uid — sem
// consulta cruzada ao Firestore (mais robusto, evita 403 intermitente).
service firebase.storage {
  match /b/{bucket}/o {
    match /tenants/{tenantId}/{allPaths=**} {
      // Leitura pública: logos/imagens aparecem em orçamentos e links públicos.
      allow read: if true;
      // Escrita: apenas o dono do tenant (uid == tenantId), imagens até 5MB.
      allow write: if request.auth != null
                   && request.auth.uid == tenantId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Anexos de relatos de bug — o autor escreve na própria pasta; leitura só
    // para o autor ou admins/devs. Prints e arquivos até 10MB.
    match /bugReports/{uid}/{allPaths=**} {
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024;
      allow read: if request.auth != null
                  && (request.auth.uid == uid
                      || request.auth.token.email in [
                        "ads.deyvid@gmail.com", "deyvid.win7@gmail.com", "pvrgeral@gmail.com"
                      ]);
    }

    // Assets do Bio público (logo + cover). Leitura pública, escrita só admin,
    // imagem até 5MB. Paths: bio/logo/<file>, bio/cover/<file>.
    match /bio/{kind}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email in [
                     "ads.deyvid@gmail.com", "deyvid.win7@gmail.com", "pvrgeral@gmail.com",
                   ]
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
