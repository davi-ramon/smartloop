rules_version = '2';

// Arquivos do SmartLoop (logos, fotos de OS, comprovantes) isolados por tenant.
service firebase.storage {
  match /b/{bucket}/o {

    function myTenant() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.tenantId;
    }

    match /tenants/{tenantId}/{allPaths=**} {
      // Leitura pública: logos aparecem em orçamentos/links públicos.
      allow read: if true;
      // Escrita: apenas o dono do tenant, imagens até 5MB.
      allow write: if request.auth != null
                   && myTenant() == tenantId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
